# ==============================================================================
# DATA & DATASETS
# ==============================================================================
# Ignore entire data directory but keep .gitkeep files to allow folder structure
data/*
!data/.gitkeep
!data/**/.gitkeep

# Data files:
*.csv
*.xlsx
*.xls

# ==============================================================================
# IMAGES (Global Ignore)
# ==============================================================================
# Ignore images globally, but you can un-ignore specific folders or files if needed
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.tif
*.webp

# EXCEPTION: If you have specific images that are essential for the demo, 
# you can un-ignore them like this:
# !demo/assets/*.png
# !README_images/

# ==============================================================================
# MODELS & CHECKPOINTS
# ==============================================================================
# Ignore model weights and checkpoints globally, but you can un-ignore specific
# folders or files if needed
*.pth
*.pt
*.ckpt

# EXCEPTION: If you have specific checkpoints that are essential for the demo,
# you can un-ignore them like this:
!demo/checkpoints/
!demo/checkpoints/**

# ==============================================================================
# PYTHON & ENVIRONMENTS
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
ENV/
build/
dist/
*.egg-info/
*.egg

# ==============================================================================
# IDE & OS
# ==============================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ==============================================================================
# JUPYTER & RESEARCH
# ==============================================================================
.ipynb_checkpoints/
mlruns/
.mlflow/
reports/
outputs/
results/